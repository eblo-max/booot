# Токен того же бота, что и в основном проекте (из @BotFather).
# ЗАДАЁТСЯ ТОЛЬКО В ПЕРЕМЕННЫХ ОКРУЖЕНИЯ Railway, не в коде и не в git.
BOT_TOKEN=

# Куда слать заявки — ваш личный числовой Telegram ID.
# Как узнать: напишите боту @userinfobot, он пришлёт ваш id (например 123456789).
# Важно: вы должны хотя бы раз написать /start самому боту-получателю,
# иначе Telegram не разрешит боту написать вам первым.
LEAD_CHAT_ID=

# Необязательно. Заполняйте, только если лендинг живёт на ДРУГОМ домене,
# а этот сервис отдаёт лишь /api/lead. Тогда впишите адрес лендинга,
# например https://vykup-ooo.ru — включится CORS. Если сервис отдаёт и
# страницу, и API (по умолчанию) — оставьте пустым.
ALLOWED_ORIGIN=
