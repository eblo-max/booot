# Telegram
BOT_TOKEN=123456:AA...
ADMIN_IDS=123456789

# Database (Railway подставляет DATABASE_URL автоматически)
DATABASE_URL=postgresql+asyncpg://bot:bot@localhost:5432/bot

# Providers. Пусто = провайдер выключен.
DATANEWTON_API_KEY=
CHECKO_API_KEY=

# Какой провайдер отдаёт массовый список: datanewton | checko | excel | fake
PRIMARY_PROVIDER=fake

# Прочее
LOG_LEVEL=INFO
